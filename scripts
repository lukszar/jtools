jstatus() {
  # Get active sprint info
  local sprintLine
  sprintLine=$(jira sprint list --table --plain --no-headers --columns ID,NAME,START,END,STATE --state active 2>/dev/null | head -1)

  if [[ -z "$sprintLine" ]]; then
    echo "No active sprint found."
    return 1
  fi

  local sprintId sprintName sprintStart sprintEnd
  sprintId=$(echo "$sprintLine" | awk -F'\t' '{print $1}')
  sprintName=$(echo "$sprintLine" | awk -F'\t' '{print $2}')
  sprintStart=$(echo "$sprintLine" | awk -F'\t' '{print $3}' | cut -c1-10)
  sprintEnd=$(echo "$sprintLine" | awk -F'\t' '{print $4}' | cut -c1-10)

  # Calculate days remaining
  local today endEpoch todayEpoch daysLeft
  today=$(date +%Y-%m-%d)
  endEpoch=$(date -j -f "%Y-%m-%d" "$sprintEnd" "+%s" 2>/dev/null)
  todayEpoch=$(date -j -f "%Y-%m-%d" "$today" "+%s" 2>/dev/null)
  daysLeft=$(( (endEpoch - todayEpoch) / 86400 ))

  # Get all issues in current sprint via JQL (matches jsprint)
  local issueData
  issueData=$(jira issue list --jql "sprint in openSprints()" --plain --no-headers --columns STATUS 2>/dev/null)

  local total countDone inProgress todo blocked
  total=$(echo "$issueData" | grep -c .)
  countDone=$(echo "$issueData" | awk -F'\t' '{print $2}' | grep -cE "^(Gotowe|Deployed on Prod|Rejected|Disabled)$")
  inProgress=$(echo "$issueData" | awk -F'\t' '{print $2}' | grep -cE "^(W toku|Code Review|Deployed on Dev|Ready for UAT|Ready for Prod|To Mobile Test|To Merge|Release Candidate Setup)$")
  todo=$(echo "$issueData" | awk -F'\t' '{print $2}' | grep -c "^Do zrobienia$")
  blocked=$(echo "$issueData" | awk -F'\t' '{print $2}' | grep -c "^Blocked$")

  # Progress bar
  local pct barFilled barEmpty bar
  if (( total > 0 )); then
    pct=$(( countDone * 100 / total ))
  else
    pct=0
  fi
  barFilled=$(( pct / 5 ))
  barEmpty=$(( 20 - barFilled ))
  bar=$(printf '%0.s█' $(seq 1 $barFilled 2>/dev/null))$(printf '%0.s░' $(seq 1 $barEmpty 2>/dev/null))

  echo ""
  echo "📊 Sprint Dashboard — $sprintName"
  echo "======================================"
  echo ""
  echo "  🗓   Period      $sprintStart → $sprintEnd"
  if (( daysLeft < 0 )); then
    echo "  ⚠️   Overdue     Sprint ended $(( daysLeft * -1 )) day(s) ago"
  else
    echo "  ⏳  Days left   $daysLeft day(s)"
  fi
  echo ""
  echo "  📋  Total       $total issues"
  echo "  ✅  Done        $countDone"
  echo "  🔄  In Progress $inProgress"
  echo "  🕐  To Do       $todo"
  echo ""
  echo "      Progress    [$bar] $pct%"
  echo ""

  if (( blocked > 0 )); then
    echo "  🚨  Blocked     $blocked task(s) — check jdoctor"
    echo ""
    echo "======================================"
  fi
}

jdoctor() {
  echo ""
  echo "🩺 jdoctor — issues requiring attention"
  echo "========================================="

  echo ""
  echo "⚠️  In Progress or Blocked Tasks — unassigned"
  echo "-----------------------------------------"
  jira issue list --jql 'statusCategory = "In Progress" AND issuetype = Task AND assignee is EMPTY'

  echo ""
  echo "⚠️  In Progress Tasks — not estimated"
  echo "-----------------------------------------"
  jira issue list --jql 'statusCategory = "In Progress" AND issuetype = Task AND Estimation is EMPTY'

  echo ""
  echo "⚠️  In Progress Tasks — no description"
  echo "-----------------------------------------"
  jira issue list --jql 'statusCategory = "In Progress" AND issuetype = Task AND description is EMPTY'

  echo ""
}

jrefi() {
  jira issue list --jql 'statusCategory != Done AND status = "In Refinement" AND Estimation is EMPTY'
}

jsprint() {
  jira issue list --jql "sprint in openSprints()"
}

jopen() {
  [[ -z "$1" ]] && { echo "Usage: jopen <ISSUE-KEY>"; return 1; }
  jira open "$1"
}