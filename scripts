#!/bin/zsh

alias jmine='jira issue list --jql "assignee = currentUser() AND sprint in openSprints()"'

jnow() {
  jira issue list --jql "assignee = currentUser() AND sprint in openSprints() AND statusCategory != Done"
}


_jql_search() {

  local onlyTitle=false
  local onlyDesc=false
  local currentSprint=false
  local onlyMine=false
  local onlyOpen=false
  local fuzzy=false
  local issueType=

  local terms=()

  # Expand combined flags like -mot into -m -o -t
  local expandedArgs=()
  for arg in "$@"; do
    if [[ "$arg" =~ ^-[tdcmofs]+$ ]]; then
      for (( i=2; i<=${#arg}; i++ )); do
        expandedArgs+=("-${arg[$i]}")
      done
    else
      expandedArgs+=("$arg")
    fi
  done

  # Parse args
  for arg in "${expandedArgs[@]}"; do
    case "$arg" in
      -t) onlyTitle=true ;;
      -d) onlyDesc=true ;;
      -c) currentSprint=true ;;
      -s) currentSprint=true ;;
      -m) onlyMine=true ;;
      -o) onlyOpen=true ;;
      -f) fuzzy=true ;;
      --task) issueType="Task" ;;
      --bug) issueType="Bug" ;;
      --epic) issueType="Epic" ;;
      *) terms+=("$arg") ;;
    esac
  done

  # Fuzzy: split space-separated string into individual terms
  if $fuzzy; then
    local fuzzyTerms=()
    for term in "${terms[@]}"; do
      fuzzyTerms+=(${=term})
    done
    terms=("${fuzzyTerms[@]}")
  fi

  # Build JQL parts
  local jqlParts=()

  $onlyMine && jqlParts+=("assignee = currentUser()")
  $currentSprint && jqlParts+=("sprint in openSprints()")
  $onlyOpen && jqlParts+=("statusCategory != Done")
  [[ -n "$issueType" ]] && jqlParts+=("issuetype = \"$issueType\"")

  # Default search scope
  if ! $onlyTitle && ! $onlyDesc; then
    onlyTitle=true
    onlyDesc=true
  fi

  # Text search
  if [ ${#terms[@]} -gt 0 ]; then
    local termClauses=()

    for term in "${terms[@]}"; do
      local fieldClause=()

      $onlyTitle && fieldClause+=("summary ~ \"$term\"")
      $onlyDesc && fieldClause+=("description ~ \"$term\"")

      termClauses+=("(${(j: OR :)fieldClause})")
    done

    jqlParts+=("(${(j: AND :)termClauses})")
  fi

  # Join full query
  local finalJQL
  finalJQL="${(j: AND :)jqlParts}"

  # Run
  if [[ -z "$finalJQL" ]]; then
    echo "Usage: jsearch [flags] [terms...]"; return 1
  fi
  jira issue list --jql "$finalJQL"
}

alias jsearch='_jql_search'
alias jfind='_jql_search'

